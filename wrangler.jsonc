{
  "name": "tva-app-issou",
  "main": "src/index.js",
  "compatibility_date": "2026-07-14",
  "containers": [
    {
      "class_name": "TvaContainer",
      "image": "./Dockerfile",
      "max_instances": 2
    }
  ],
  "durable_objects": {
    "bindings": [
      {
        "name": "TVA_CONTAINER",
        "class_name": "TvaContainer"
      }
    ]
  },
  "migrations": [
    {
      "tag": "v1",
      "new_sqlite_classes": ["TvaContainer"]
    }
  ]
}
